# ~/.bash_secrets - per-machine bash overrides.
#
# This file is sourced from ~/.bash_common at the end of interactive shell
# startup. It is intentionally NOT tracked in the bare dotfiles repo, so
# anything machine-specific or sensitive belongs here:
#   - CUDA / toolchain paths
#   - Cluster-only mounts and scratch dirs
#   - API tokens, shell aliases that reveal hostnames, etc.
#
# `bootstrap.sh --bash` will copy this template to ~/.bash_secrets the
# first time it runs on a machine (only if ~/.bash_secrets is missing).
# Edit ~/.bash_secrets afterwards, not this example.

# --- Example: CUDA 13.1 ---
# Uncomment and adjust the version/path for the host's CUDA install.
# export PATH=/usr/local/cuda-13.1/bin${PATH:+:${PATH}}
# export LD_LIBRARY_PATH=/usr/local/cuda-13.1/lib64${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}

# --- Example: extra PATH entries ---
# export PATH="$HOME/scratch/bin:$PATH"

# --- Example: tokens ---
# Prefer reading from a credentials file rather than inlining secrets here.
# export OPENAI_API_KEY="$(cat ~/.config/openai/key 2>/dev/null)"
